SECRET_KEY=django-insecure-replace-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── JWT ───────────────────────────────────────────────────────────────────
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7
JWT_ACCESS_COOKIE_NAME=move_access_token
JWT_REFRESH_COOKIE_NAME=move_refresh_token

# Set to True in production (HTTPS only)
JWT_COOKIE_SECURE=False
# Lax for same-site dev; use "None" + Secure=True for cross-site prod
JWT_COOKIE_SAMESITE=Lax

# ─── CORS / CSRF ───────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost
